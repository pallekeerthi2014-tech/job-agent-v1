COMPOSE_PROJECT_NAME=job-agent-v1
POSTGRES_DB=job_ops
POSTGRES_USER=job_ops
POSTGRES_PASSWORD=job_ops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=
API_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
DAILY_JOB_HOUR=6
DAILY_JOB_MINUTE=0
DEFAULT_QUEUE_LIMIT=50
FRESH_JOB_MAX_AGE_HOURS=48
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
RESET_TOKEN_EXPIRE_MINUTES=60
RESUME_STORAGE_PATH=/app/resumes
PUBLIC_APP_URL=http://localhost:5173
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@thinksuccessitconsulting.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
EMPLOYEE_DEFAULT_PASSWORD=ThinkSuccess123!
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SEED_SAMPLE_CANDIDATES=false

# ── Phase 2: Real-Time Polling ────────────────────────────────────────────────
# How often the pipeline runs (minutes). Default: 15
POLL_INTERVAL_MINUTES=15

# ── Phase 2: Alert Thresholds ─────────────────────────────────────────────────
# Minimum match score (0–100) to trigger a Slack/email alert. Default: 65
ALERT_MIN_SCORE=65

# ── Phase 2: WhatsApp Alerts (Twilio) ────────────────────────────────────────
# Setup steps:
#   1. Sign up at twilio.com → get Account SID + Auth Token from Console
#   2. Enable WhatsApp Sandbox (dev) or apply for a production WhatsApp number
#   3. Set TWILIO_WHATSAPP_FROM to your Twilio WhatsApp number (e.g. whatsapp:+14155238886)
#   4. Set WHATSAPP_TEAM_NUMBERS to comma-separated team numbers in +E.164 format
#   5. Flip WHATSAPP_ALERTS_ENABLED=true
WHATSAPP_ALERTS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# All team members who should receive alerts (comma-separated, include country code):
WHATSAPP_TEAM_NUMBERS=+1xxxxxxxxxx,+1xxxxxxxxxx

# ── Phase 2: Email Alerts ─────────────────────────────────────────────────────
# Reuses existing SMTP settings above. Set to true to enable per-recruiter emails.
EMAIL_ALERTS_ENABLED=false

# ── Phase 2: AI Scoring Enrichment ───────────────────────────────────────────
# Set AI_SCORING_ENABLED=true AFTER confirming live feeds work correctly.
# Adds plain-English match summaries, strengths, and gaps to each alert.
AI_SCORING_ENABLED=false

# Choose provider: openai (default) or anthropic
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

OPENAI_API_KEY=
# Or use Anthropic Claude (most cost-effective):
# AI_PROVIDER=anthropic
# AI_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=

# ── Phase 2: USAJobs API (optional) ──────────────────────────────────────────
# Register free at https://developer.usajobs.gov/
USAJOBS_API_KEY=
