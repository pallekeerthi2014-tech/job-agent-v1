# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  ThinkSuccess Job Alert Platform — Environment Configuration                ║
# ║  Copy this file to .env and fill in all values before starting.             ║
# ║                                                                              ║
# ║  PRODUCTION CHECKLIST:                                                       ║
# ║  □ JWT_SECRET_KEY        — generate with: openssl rand -hex 32              ║
# ║  □ SUPER_ADMIN_PASSWORD  — change from default                              ║
# ║  □ EMPLOYEE_DEFAULT_PASSWORD — change from default                          ║
# ║  □ POSTGRES_PASSWORD     — use a strong password                            ║
# ║  □ ALLOWED_ORIGINS       — set to your frontend domain                      ║
# ║  □ PUBLIC_APP_URL        — set to your deployed URL                         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

COMPOSE_PROJECT_NAME=job-agent-v1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=job_ops
POSTGRES_USER=job_ops
POSTGRES_PASSWORD=job_ops          # CHANGE IN PRODUCTION
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=                       # Leave blank — auto-constructed from above

# ── Backend / Frontend ports ──────────────────────────────────────────────────
API_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000   # Set to your deployed backend URL in prod

# ── CORS & public URL ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_APP_URL=http://localhost:5173      # Set to your deployed frontend URL in prod

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
RESET_TOKEN_EXPIRE_MINUTES=60

# ── Admin bootstrap ───────────────────────────────────────────────────────────
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@thinksuccessitconsulting.com
SUPER_ADMIN_PASSWORD=ChangeMe123!         # CHANGE IN PRODUCTION
EMPLOYEE_DEFAULT_PASSWORD=ThinkSuccess123! # CHANGE IN PRODUCTION

# ── SMTP / Email (for password reset + email alerts) ─────────────────────────
# Gmail example: smtp.gmail.com port 587, use an App Password (not your login password)
# SendGrid example: smtp.sendgrid.net port 587, username=apikey, password=<API_KEY>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
DAILY_JOB_HOUR=6
DAILY_JOB_MINUTE=0
POLL_INTERVAL_MINUTES=15            # How often the pipeline runs (minutes)

# ── Job pipeline ──────────────────────────────────────────────────────────────
DEFAULT_QUEUE_LIMIT=50
FRESH_JOB_MAX_AGE_HOURS=168        # Jobs older than this are excluded (7 days)
SEED_SAMPLE_CANDIDATES=false

# ── Alert thresholds ──────────────────────────────────────────────────────────
ALERT_MIN_SCORE=65                  # Minimum match score (0–100) to trigger alerts

# ── WhatsApp Alerts (Twilio) ──────────────────────────────────────────────────
# Setup:
#   1. Create a Twilio account at https://twilio.com
#   2. DEV:  Enable WhatsApp Sandbox (Console → Messaging → Try it out → WhatsApp)
#      PROD: Apply for a Twilio production WhatsApp sender at
#            https://console.twilio.com/us1/develop/sms/senders/whatsapp-senders
#   3. Copy ACCOUNT SID + AUTH TOKEN from https://console.twilio.com
#   4. Set TWILIO_WHATSAPP_FROM to your Twilio number (with whatsapp: prefix)
#   5. Set WHATSAPP_TEAM_NUMBERS to comma-separated recipient numbers (+E.164)
#      OR manage recipients directly in the Admin → WhatsApp Alerts UI
#   6. Set WHATSAPP_ALERTS_ENABLED=true
WHATSAPP_ALERTS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox default; change for prod
WHATSAPP_TEAM_NUMBERS=+1xxxxxxxxxx,+1xxxxxxxxxx  # Fallback if DB recipients are empty

# ── Email Alerts ──────────────────────────────────────────────────────────────
# Reuses SMTP settings above. Sends per-recruiter HTML emails for high-score matches.
EMAIL_ALERTS_ENABLED=false

# ── AI Scoring Enrichment ─────────────────────────────────────────────────────
# Adds plain-English match summaries, strengths, and gaps to each score.
# Enable AFTER confirming live feeds work — adds ~$0.001 per match scored.
AI_SCORING_ENABLED=false

# Provider: openai (default, gpt-4o-mini) or anthropic (claude-haiku-4-5-20251001)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Anthropic alternative (lower cost):
# AI_PROVIDER=anthropic
# AI_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=

# ── Candidate Gmail Analytics (Google Sheet reporting) ───────────────────────
# OAuth client is owned by Thinksuccess.ITConsultants@gmail.com.
# Do not store Gmail passwords. Candidate mailboxes connect through read-only OAuth.
GMAIL_ANALYTICS_ENABLED=false
GMAIL_SCAN_INTERVAL_MINUTES=30
GMAIL_SCAN_LOOKBACK_DAYS=14
GMAIL_CALENDAR_LOOKAHEAD_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/admin/gmail/oauth/callback
# Generate with: cd apps/backend && python scripts/generate_google_token_key.py
GOOGLE_TOKEN_ENCRYPTION_KEY=
# Create a Sheet under the company Gmail and share it with the Cloud Run service account as Editor.
GOOGLE_SHEETS_REPORT_ID=

# ── USAJobs API (optional — US Government job listings) ───────────────────────
# Register free at https://developer.usajobs.gov/
# Leave blank to disable USAJobs feed.
USAJOBS_API_KEY=
USAJOBS_USER_AGENT_EMAIL=ops@thinksuccessitconsulting.com
